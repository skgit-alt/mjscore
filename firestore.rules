rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全員読み取り可能
    match /{document=**} {
      allow read: if true;
    }

    // 書き込みは認証済みユーザーのみ
    match /games/{gameId} {
      allow create, update, delete: if request.auth != null;
    }

    match /players/{playerId} {
      allow create, update, delete: if request.auth != null;
    }

    match /settings/{settingId} {
      allow create, update, delete: if request.auth != null;
    }
  }
}
